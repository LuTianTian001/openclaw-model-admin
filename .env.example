# 复制为 .env 后按需修改（不要把 .env 提交到 Git）
# 一键 install.sh 在无 .env 时会自动复制本文件（可用 INSTALL_COPY_ENV=0 关闭）
# 与网关数据不在 ~/.openclaw 时，推荐只设目录：
# OPENCLAW_HOME=/home/you/.openclaw
# OPENCLAW_CONFIG_PATH=/home/you/.openclaw/openclaw.json
# 可不设：默认 = openclaw.json 所在目录下的 agents/main/sessions/sessions.json
# OPENCLAW_SESSIONS_PATH=/home/you/.openclaw/agents/main/sessions/sessions.json
# OPENCLAW_GATEWAY_SERVICE=openclaw-gateway.service
# 无 systemd 或需 docker/脚本重启时（整行一条 shell 命令）：
# OPENCLAW_GATEWAY_RESTART_COMMAND=/usr/bin/sudo /bin/systemctl restart openclaw-gateway.service
# 状态与「自定义重启」后的就绪探测（HTTP，推荐）：
# OPENCLAW_GATEWAY_HEALTH_URL=http://127.0.0.1:18789/
# 仅 ss 回退时用，逗号分隔子串：
# OPENCLAW_GATEWAY_SS_MARKERS=127.0.0.1:18789,[::1]:18789
# journalctl 不可用或无权限时，管理端「网关日志」可改读文件尾部：
# OPENCLAW_GATEWAY_LOG_FILE=/var/log/openclaw/gateway.log
# 配置 + sessions 自动备份（默认在 openclaw.json 同目录下 openclaw-model-admin-backups/，每小时、保留 7 天）
# OPENCLAW_ADMIN_BACKUP_DIR=/path/to/backups
# OPENCLAW_ADMIN_BACKUP_RETENTION_DAYS=7
# OPENCLAW_ADMIN_BACKUP_INTERVAL_SEC=3600
# OPENCLAW_ADMIN_BACKUP_DISABLE=0
# OPENCLAW_MODEL_ADMIN_HOST=0.0.0.0
# OPENCLAW_MODEL_ADMIN_PORT=8765
# 管理端页内「本机信息」展示用版本号（便于多台对照）
# OPENCLAW_MODEL_ADMIN_VERSION=1.2.0
# OPENCLAW_MODEL_ADMIN_PREFS_PATH=./admin-prefs.json
# 无 openclaw CLI 时仅用于测试（生产勿开）：跳过 config validate
# OPENCLAW_MODEL_ADMIN_SKIP_VALIDATE=0
# 调试：禁止 /api/state 缓存 openclaw validate 结果（每次刷新都跑 CLI，较慢）
# OPENCLAW_MODEL_ADMIN_DISABLE_STATE_VALIDATE_CACHE=1
# POST JSON 体最大字节数（默认 8MiB，与监听地址无关）
# OPENCLAW_MODEL_ADMIN_MAX_BODY_BYTES=8388608
# NFS 等环境 flock 异常时可关闭（仅影响本进程内对 openclaw.json 的并发保护）
# OPENCLAW_MODEL_ADMIN_DISABLE_CONFIG_LOCK=0
# OpenClaw CLI 版本检查：npm 最新版缓存周期（秒），默认 43200=12h；与前端轮询对齐
# OPENCLAW_ADMIN_OPENCLAW_VERSION_CHECK_SEC=43200
# 本机 openclaw -V 进程内缓存（秒），减轻 /api/state 压力，默认 120
# OPENCLAW_ADMIN_OPENCLAW_CLI_CACHE_SEC=120
# 禁止网页「更新 OpenClaw」按钮（POST /api/openclaw/update）
# OPENCLAW_ADMIN_OPENCLAW_UPDATE_DISABLE=1
# 一键更新超时（秒），默认 1800
# OPENCLAW_ADMIN_OPENCLAW_UPDATE_TIMEOUT_SEC=1800
