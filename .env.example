# 复制为 .env 后按需修改（不要把 .env 提交到 Git）
# 与网关数据不在 ~/.openclaw 时，推荐只设目录：
# OPENCLAW_HOME=/home/you/.openclaw
# OPENCLAW_CONFIG_PATH=/home/you/.openclaw/openclaw.json
# 可不设：默认 = openclaw.json 所在目录下的 agents/main/sessions/sessions.json
# OPENCLAW_SESSIONS_PATH=/home/you/.openclaw/agents/main/sessions/sessions.json
# OPENCLAW_GATEWAY_SERVICE=openclaw-gateway.service
# 无 systemd 或需 docker/脚本重启时（整行一条 shell 命令）：
# OPENCLAW_GATEWAY_RESTART_COMMAND=/usr/bin/sudo /bin/systemctl restart openclaw-gateway.service
# 状态与「自定义重启」后的就绪探测（HTTP，推荐）：
# OPENCLAW_GATEWAY_HEALTH_URL=http://127.0.0.1:18789/
# 仅 ss 回退时用，逗号分隔子串：
# OPENCLAW_GATEWAY_SS_MARKERS=127.0.0.1:18789,[::1]:18789
# OPENCLAW_MODEL_ADMIN_HOST=0.0.0.0
# OPENCLAW_MODEL_ADMIN_PORT=8765
# OPENCLAW_MODEL_ADMIN_PREFS_PATH=./admin-prefs.json
# 无 openclaw CLI 时仅用于测试（生产勿开）：跳过 config validate
# OPENCLAW_MODEL_ADMIN_SKIP_VALIDATE=0
